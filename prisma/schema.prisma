// MindSpace Database Schema - Simplified for Phase 2

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  pseudonym     String
  avatarColor   String
  avatarEmoji   String
  age           Int?
  language      String    @default("en")
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile     Profile?
  journalEntries JournalEntry[]
  moodLogs    MoodLog[]
  posts       Post[]
  comments    Comment[]
  progress    Progress[]
  reactions   Reaction[]
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  primaryConcern  String[]
  riskTolerance   String?
  crisisContact   String?
  notificationsOn Boolean  @default(true)
  reminderTime    String?
  premiumUser     Boolean  @default(false)
  joinedCircles   String[]
  onboardingComplete Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id          String   @id @default(cuid())
  userId      String
  content     String
  mood        String
  moodScore   Int
  tags        String[]
  aiResponse  String?
  isCrisis    Boolean  @default(false)
  crisisRiskLevel String?
  wordCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, mood])
}

model MoodLog {
  id          String   @id @default(cuid())
  userId      String
  mood        String
  moodScore   Int
  tags        String[]
  loggedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
}

model Circle {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  emoji       String
  description String
  color       String
  memberCount Int      @default(0)
  postCount   Int      @default(0)
  createdAt   DateTime @default(now())

  posts Post[]
}

model Post {
  id          String    @id @default(cuid())
  userId      String
  circleId    String
  type        String
  content     String
  contentWarning String?
  isHidden    Boolean   @default(false)
  reportCount Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  circle   Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  comments Comment[]
  reactions Reaction[]

  @@index([circleId, createdAt])
  @@index([userId])
}

model Comment {
  id          String   @id @default(cuid())
  postId      String
  userId      String
  content     String
  isHidden    Boolean  @default(false)
  reportCount Int      @default(0)
  createdAt   DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model Reaction {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  type      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, type])
}

model Resource {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String
  duration    Int?
  emoji       String
  content     String?
  url         String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  progress Progress[]
}

model Progress {
  id          String    @id @default(cuid())
  userId      String
  resourceId  String
  completed   Boolean   @default(false)
  completedAt DateTime?
  progress    Int       @default(0)
  updatedAt   DateTime  @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
}

model Habit {
  id        String   @id @default(cuid())
  name      String
  emoji     String
  createdAt DateTime @default(now())
}

model HabitLog {
  id        String   @id @default(cuid())
  userId    String
  habitId   String
  completed Boolean  @default(false)
  loggedAt  DateTime @default(now())

  @@unique([userId, habitId, loggedAt])
}

model Badge {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String
  emoji       String
  createdAt   DateTime @default(now())
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeId])
}
